# ─────────────────────────────────────────────
#  kinetic-backend — variáveis de ambiente
#  Copie este arquivo para `.env` e preencha os valores.
#    cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#  O `.env` NÃO é versionado.
# ─────────────────────────────────────────────

# ─── Banco de dados (PostgreSQL / Supabase) ──
# URL JDBC do PostgreSQL (ex.: pooler do Supabase)
DB_URL=jdbc:postgresql://localhost:5432/postgres
# Usuário do banco (no Supabase: postgres.<project-id>)
DB_USERNAME=postgres
# Senha do banco (use aspas se houver caracteres especiais)
DB_PASSWORD="your-database-password"

# ─── JWT ─────────────────────────────────────
# Segredo p/ assinar os tokens — base64, >= 256 bits.
# Gere um aleatório com: openssl rand -base64 64
JWT_SECRET=change-me-to-a-base64-secret-of-at-least-256-bits
# Validade do access token, em milissegundos (ex.: 86400000 = 24h)
JWT_EXPIRATION_MS=86400000
# Validade do refresh token, em milissegundos (ex.: 2592000000 = 30 dias)
JWT_REFRESH_EXPIRATION_MS=2592000000

# ─── Supabase Storage (upload de fotos do feed social) ─
# Base do projeto Supabase (mesma do banco). Ex.: https://<project-id>.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co
# service_role secret key (Project Settings → API). NÃO use a anon. Fica só no backend.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Nome do bucket PÚBLICO criado no Storage.
SUPABASE_STORAGE_BUCKET=social-media

# ─── Google Gemini (geração de treinos por IA) ─
GOOGLE_AI_API_KEY=your-google-gemini-api-key

# ─── CORS (opcional) ─────────────────────────
# Origens liberadas, separadas por vírgula.
# Default: http://localhost:8081,http://localhost:19006
# CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
