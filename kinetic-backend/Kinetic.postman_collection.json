{
  "info": {
    "name": "Kinetic Backend API",
    "_postman_id": "b2c3d4e5-0001-4a2b-9c3d-kinetic000001",
    "description": "Coleção completa da API do kinetic-backend (Spring Boot).\n\n## Como usar\n1. Suba o backend: `cd kinetic-backend && ./mvnw spring-boot:run` (Windows: `.\\mvnw.cmd spring-boot:run`).\n2. Confira a variável de coleção `baseUrl` (padrão `http://localhost:8080`).\n3. Rode **Auth > Register** (cria o usuário) e depois **Auth > Login**.\n   - O login salva `accessToken`, `refreshToken` e `userId` automaticamente (script na aba *Scripts/Tests*).\n4. Os demais endpoints já usam `Authorization: Bearer {{accessToken}}` herdado da coleção.\n5. Quando o access token expirar (padrão 24h), rode **Auth > Refresh** para renovar.\n\nRotas públicas: apenas `/api/auth/**`. Todo o resto exige o Bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "workoutPlanId", "value": "" },
    { "key": "exerciseId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Test User\",\n  \"email\": \"test@kinetic.com\",\n  \"senha\": \"Senha@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "description": "Cria um usuário. A senha deve ter 8–20 chars com ao menos 1 maiúscula, 1 minúscula e 1 caractere especial."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  if (json.id) pm.collectionVariables.set('userId', json.id);",
                  "  console.log('Tokens salvos. userId =', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@kinetic.com\",\n  \"senha\": \"Senha@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "Autentica e salva accessToken/refreshToken/userId nas variáveis da coleção."
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  console.log('Access token renovado.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] },
            "description": "Gera um novo par de tokens a partir do refreshToken."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] },
            "description": "Invalida o refresh token."
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@kinetic.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/verify-email", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify-email"] },
            "description": "Verifica se o e-mail existe (passo do fluxo de recuperação de senha)."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@kinetic.com\",\n  \"newPassword\": \"NovaSenha@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "reset-password"] },
            "description": "Redefine a senha. Mesma regra de complexidade do register."
          }
        }
      ]
    },
